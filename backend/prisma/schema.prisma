generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

enum FoodStatus {
  allowed
  testing
  caution
  avoid
}

enum UserRole {
  owner
  member
  readonly
}

model Food {
  id               String        @id @default(cuid())
  name             String
  category         String
  status           FoodStatus
  tolerance        Int
  notes            String?
  suggestedServing String?
  tags             String[]
  createdAt        DateTime      @default(now())
  updatedAt        DateTime      @updatedAt
  mealLogs         MealLogFood[]
  preferences      FoodPreference[]

  @@index([category])
  @@index([status])
}

model FoodPreference {
  userId    String
  foodId    String
  status    FoodStatus
  tolerance Int
  notes     String?
  createdAt DateTime   @default(now())
  updatedAt DateTime   @updatedAt
  user      AppUser    @relation(fields: [userId], references: [id])
  food      Food       @relation(fields: [foodId], references: [id], onDelete: Cascade)

  @@id([userId, foodId])
  @@index([foodId])
  @@index([userId, status])
}

model Recipe {
  id              String    @id @default(cuid())
  userId          String
  user            AppUser   @relation(fields: [userId], references: [id])
  name            String
  description     String?
  ingredients     String[]
  steps           String[]
  tags            String[]
  prepTimeMinutes Int
  rating          Int?
  createdAt       DateTime  @default(now())
  updatedAt       DateTime  @updatedAt
  mealLogs        MealLog[]

  @@index([userId, name])
  @@index([userId, rating])
  @@index([name])
  @@index([rating])
}

model MealLog {
  id            String         @id @default(cuid())
  userId        String
  user          AppUser        @relation(fields: [userId], references: [id])
  consumedAt    DateTime
  description   String
  notes         String?
  recipeId      String?
  recipe        Recipe?        @relation(fields: [recipeId], references: [id], onDelete: SetNull)
  createdAt     DateTime       @default(now())
  updatedAt     DateTime       @updatedAt
  symptomLogs   SymptomLog[]
  foods         MealLogFood[]
  treatmentLogs TreatmentLog[]

  @@index([userId, consumedAt])
  @@index([consumedAt])
  @@index([recipeId])
}

model MealLogFood {
  mealLogId String
  foodId    String
  createdAt DateTime @default(now())
  mealLog   MealLog  @relation(fields: [mealLogId], references: [id], onDelete: Cascade)
  food      Food     @relation(fields: [foodId], references: [id], onDelete: Cascade)

  @@id([mealLogId, foodId])
  @@index([foodId])
}

model SymptomLog {
  id            String         @id @default(cuid())
  userId        String
  user          AppUser        @relation(fields: [userId], references: [id])
  loggedAt      DateTime
  bloating      Int
  pain          Int
  gas           Int
  transit       Int
  energy        Int
  sleep         Int
  notes         String?
  mealLogId     String?
  mealLog       MealLog?       @relation(fields: [mealLogId], references: [id], onDelete: SetNull)
  createdAt     DateTime       @default(now())
  updatedAt     DateTime       @updatedAt
  treatmentLogs TreatmentLog[]

  @@index([userId, loggedAt])
  @@index([loggedAt])
  @@index([mealLogId])
}

model Treatment {
  id        String         @id @default(cuid())
  userId    String
  user      AppUser        @relation(fields: [userId], references: [id])
  name      String
  category  String
  targets   String[]
  status    String
  startDate DateTime?
  endDate   DateTime?
  notes     String?
  createdAt DateTime       @default(now())
  updatedAt DateTime       @updatedAt
  logs      TreatmentLog[]

  @@index([userId, category])
  @@index([userId, status])
  @@index([category])
  @@index([status])
}

model TreatmentLog {
  id                  String      @id @default(cuid())
  userId              String
  user                AppUser     @relation(fields: [userId], references: [id])
  treatmentId         String
  treatment           Treatment   @relation(fields: [treatmentId], references: [id], onDelete: Cascade)
  takenAt             DateTime
  dose                String?
  timing              String?
  relatedMealLogId    String?
  relatedMealLog      MealLog?    @relation(fields: [relatedMealLogId], references: [id], onDelete: SetNull)
  relatedSymptomLogId String?
  relatedSymptomLog   SymptomLog? @relation(fields: [relatedSymptomLogId], references: [id], onDelete: SetNull)
  notes               String?
  createdAt           DateTime    @default(now())
  updatedAt           DateTime    @updatedAt

  @@index([userId, takenAt])
  @@index([takenAt])
  @@index([treatmentId])
  @@index([relatedMealLogId])
  @@index([relatedSymptomLogId])
}

model AppUser {
  id                    String         @id @default(cuid())
  username              String         @unique
  email                 String?        @unique
  displayName           String?
  role                  UserRole       @default(member)
  active                Boolean        @default(true)
  passwordHash          String
  foodPreferences       FoodPreference[]
  recipes               Recipe[]
  mealLogs              MealLog[]
  symptomLogs           SymptomLog[]
  treatments            Treatment[]
  treatmentLogs         TreatmentLog[]
  lastDisabledAt        DateTime?
  lastDisabledByUserId  String?
  lastEnabledAt         DateTime?
  lastEnabledByUserId   String?
  passwordResetAt       DateTime?
  passwordResetByUserId String?
  createdAt             DateTime       @default(now())
  updatedAt             DateTime       @updatedAt

  @@index([role])
  @@index([active])
}

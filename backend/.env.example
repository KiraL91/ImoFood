PORT=4000
CORS_ORIGIN=http://localhost:3000,http://localhost:3001
JWT_SECRET="replace-with-a-long-random-secret"

# Runtime API traffic. In Vercel/serverless use Supabase Transaction pooler.
DATABASE_URL="postgresql://postgres.project-ref:password@aws-0-eu-west-1.pooler.supabase.com:6543/postgres?pgbouncer=true&connection_limit=1"

# Prisma CLI and migrations. Prefer Supabase Direct Connection for this value.
DIRECT_URL="postgresql://postgres:password@db.project-ref.supabase.co:5432/postgres"

# Future AI provider/model selection.
AI_ENABLED=false
AI_PROVIDER=gemini
AI_MODEL=gemini-3.5-flash
AI_API_KEY=""
AI_BASE_URL="https://generativelanguage.googleapis.com"
AI_TEMPERATURE=0.2
AI_TIMEOUT_MS=12000
AI_MAX_OUTPUT_TOKENS=1200
